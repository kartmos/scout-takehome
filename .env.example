# Scout – development environment variables
# Copy this file to .env (which is git-ignored) and adjust values as needed.
# These are non-production example values for local development only.
# NEVER commit .env or use these credentials in production.

# MinIO / S3 connection – development credentials only, never use in production
SCOUT_S3_ENDPOINT=localhost:9000
SCOUT_S3_ACCESS_KEY=scout-dev-access
SCOUT_S3_SECRET_KEY=scout-dev-secret-key-change-me
SCOUT_S3_BUCKET=scout-photos
SCOUT_S3_SECURE=false
SCOUT_S3_REGION=us-east-1
# Presigned URL lifetimes (1s–168h). Defaults: 15m each.
SCOUT_S3_UPLOAD_TTL=15m
SCOUT_S3_DOWNLOAD_TTL=15m

# Host ports (bound to 127.0.0.1 only)
SCOUT_MINIO_API_PORT=9000
SCOUT_MINIO_CONSOLE_PORT=9001
