# Scout – development environment variables
# Copy this file to .env (which is git-ignored) and adjust values as needed.
# These are non-production example values for local development only.
# NEVER commit .env or use these credentials in production.

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# VITE_ prefix is required for Vite to expose the value to the browser bundle.

# For local docker-compose stack use /api (same-origin via nginx proxy).
# For native frontend dev (pnpm dev) use the absolute API URL.
VITE_SCOUT_API_BASE_URL=http://localhost:8080

# DEMO LIMITATION: this key is a build-time arg exposed in the browser bundle.
# It is a static single-key authentication scheme intended for demo use only.
VITE_SCOUT_API_KEY=scout-dev-api-key-do-not-use-in-production

# ── Data API ─────────────────────────────────────────────────────────────────
SCOUT_DATABASE_PATH=dataset/predictions.db
# API key must match VITE_SCOUT_API_KEY; never use this value in production.
SCOUT_API_KEY=scout-dev-api-key-do-not-use-in-production

# HTTP server
SCOUT_HTTP_ADDR=:8080
SCOUT_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
# Development credentials only — never use in production.
SCOUT_S3_ENDPOINT=localhost:9000
SCOUT_S3_ACCESS_KEY=scout-dev-access
SCOUT_S3_SECRET_KEY=scout-dev-secret-key-change-me
SCOUT_S3_BUCKET=scout-photos
SCOUT_S3_SECURE=false
SCOUT_S3_REGION=us-east-1

# Optional public endpoint for presigned URLs (host:port reachable by browser and seed container).
# When absent, presigned URLs use SCOUT_S3_ENDPOINT.
# In the docker-compose local stack this is set automatically to minio.localhost:<port>.
# SCOUT_S3_PUBLIC_ENDPOINT=minio.localhost:9000
# SCOUT_S3_PUBLIC_SECURE=false

# Presigned URL lifetimes (1s–168h). Defaults: 15m each.
SCOUT_S3_UPLOAD_TTL=15m
SCOUT_S3_DOWNLOAD_TTL=15m

# ── Thumbnail generator ───────────────────────────────────────────────────────
# max 2 — bounds concurrent decode/encode memory
SCOUT_THUMBNAIL_GENERATION_CONCURRENCY=1

# ── Thumbnail disk cache ──────────────────────────────────────────────────────
# PRODUCTION: set SCOUT_THUMBNAIL_CACHE_DIR to a persistent writable volume;
# the default /tmp/scout-thumb-cache is ephemeral (local dev only).
SCOUT_THUMBNAIL_CACHE_DIR=/tmp/scout-thumb-cache
# Maximum total cache disk usage in bytes (default 256 MiB for docker-compose).
SCOUT_THUMBNAIL_CACHE_MAX_BYTES=268435456

# ── Host port bindings (bound to 127.0.0.1 only) ─────────────────────────────
SCOUT_MINIO_API_PORT=9000
SCOUT_MINIO_CONSOLE_PORT=9001
# SCOUT_API_PORT=8080     # direct API debug port (optional; use web URL normally)
SCOUT_WEB_PORT=8090
# SCOUT_SEED_CONCURRENCY=2
