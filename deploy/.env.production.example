# Scout — production server environment (deploy/compose.server.yaml)
#
# Copy this file to /opt/scout/.env.production on the application server:
#
#   cp deploy/.env.production.example /opt/scout/.env.production
#   chmod 600 /opt/scout/.env.production
#
# /opt/scout/.env.production is never committed, printed, uploaded as a
# CI artifact, or embedded into shell history. Only the placeholders below
# (this file) live in git. See deploystepbystep.md section 7.8 for a fully
# worked example.
#
# Every value below is REQUIRED unless marked optional; deploy/compose.server.yaml
# fails fast with a readable error if a required value is missing.

# ── Public configuration (not secret, but still only lives on the server) ───

# Domain the site is served under. Must already resolve (A/AAAA) to this
# server before Caddy can obtain a certificate.
SCOUT_DOMAIN=scout.example.com

# Contact address for the Let's Encrypt ACME account (expiry/policy mail only).
SCOUT_ACME_EMAIL=admin@example.com

# GHCR image references published by .github/workflows/deploy.yml.
# Must match the lower-cased "<owner>/<repo>-api" / "<owner>/<repo>-web"
# names the workflow publishes; see the workflow job summary for the exact
# names for this repository.
SCOUT_API_IMAGE=ghcr.io/<owner>/<repo>-api
SCOUT_WEB_IMAGE=ghcr.io/<owner>/<repo>-web

# Immutable release tag to run. deploy/deploy.sh overwrites this file's copy
# on the server atomically after a successful health check; do not set it to
# "latest" or "main".
SCOUT_IMAGE_TAG=sha-0000000

# Absolute host path to the read-only SQLite database, bind-mounted into the
# api container. Upload predictions.db here first (see guide section 7.9).
SCOUT_DATABASE_PATH=/opt/scout/data/predictions.db

# CORS origin(s) the API accepts, comma-separated. Must match SCOUT_DOMAIN.
SCOUT_CORS_ALLOWED_ORIGINS=https://scout.example.com

# ── Secrets — generate real random values; never reuse the examples ─────────

# API key required on /photos* routes. Must equal the VITE_SCOUT_API_KEY the
# web image was built with (GitHub Environment secret) — see the browser-key
# limitation in README.md and deploystepbystep.md section 7.8. Browser-visible
# by design; this is a demo auth scheme, not real user authentication.
SCOUT_API_KEY=REPLACE_WITH_A_LONG_RANDOM_VALUE

# ── External S3-compatible object storage (AWS S3, R2, external MinIO, ...) ─
# Never hosted on this application server.

# Internal endpoint used by the API for bucket checks and reading originals
# during thumbnail generation. host:port, no scheme.
SCOUT_S3_ENDPOINT=s3.example-region.example.com

# Public endpoint embedded in presigned URLs returned to the browser. Only
# set this when it differs from SCOUT_S3_ENDPOINT (e.g. a CDN/public hostname
# in front of the bucket).
# SCOUT_S3_PUBLIC_ENDPOINT=cdn.example.com

SCOUT_S3_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
SCOUT_S3_SECRET_KEY=REPLACE_WITH_SECRET_KEY
SCOUT_S3_BUCKET=scout-photos-prod
SCOUT_S3_SECURE=true

# Only set this when SCOUT_S3_PUBLIC_ENDPOINT uses a different TLS posture
# than SCOUT_S3_ENDPOINT.
# SCOUT_S3_PUBLIC_SECURE=true

SCOUT_S3_REGION=us-east-1

# ── Thumbnail cache ──────────────────────────────────────────────────────────

# Bounded disk budget for the thumbnail cache volume, in bytes. Disk only —
# does not consume container RAM.
SCOUT_THUMBNAIL_CACHE_MAX_BYTES=268435456
