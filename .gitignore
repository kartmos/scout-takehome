# Local secrets (never commit)
.env
.env.local
.env.*.local

# Claude Code local settings
CLAUDE.local.md
.claude/settings.local.json

# Windows metadata
*:Zone.Identifier

# ── Backend ──────────────────────────────────────────────────────────────────
# Compiled binaries (task-018 hygiene: the historic backend/api blob is a known
# artefact in git history and will be cleaned up in task-018).
/backend/api
/backend/scout-api
/backend/scout-seed

# Go test cache (managed by the Go toolchain, not stored in the repo)
/backend/testcache/

# ── Frontend ─────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ── Docker / runtime ─────────────────────────────────────────────────────────
# Local compose overrides that may contain secrets
compose.override.yaml
compose.override.yml

# Local thumbnail cache
/tmp/scout-thumb-cache/

# Temporary SQLite artefacts
*.db-shm
*.db-wal

# ── OS and editor artefacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# Recovery archives (task-018 hygiene item)
*.tar.gz
*.zip
*.bak
