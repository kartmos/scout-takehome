# Git metadata
.git/
.gitignore

# Local secrets and environment files (never copy into image layers)
.env
.env.*
!.env.example

# Frontend build artifacts and caches
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# Backend compiled binaries and test caches
backend/api
backend/scout-api
backend/scout-seed
backend/testdata/

# Dataset: bind-mounted at runtime, not baked into images
dataset/

# Thumbnail cache (runtime volume)
/tmp/scout-thumb-cache/

# Docker override files that may contain secrets
compose.override.yaml
compose.override.yml

# Test and coverage outputs
*.test
coverage/
*.out
*.prof

# Editor and OS artifacts
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
*.iml
Thumbs.db

# Recovery archives (task-018 hygiene)
*.tar.gz
*.zip
*.bak

# Claude / AI artifacts
.claude/settings.local.json
CLAUDE.local.md
